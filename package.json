{
  "name": "dental-recommend-agent",
  "version": "1.0.0",
  "description": "牙科设备推荐Agent — B2B牙科设备智能推荐系统",
  "main": "electron/main.js",
  "author": "Dental Recommend Team",
  "license": "MIT",
  "scripts": {
    "dev": "concurrently \"cd backend && python main.py\" \"cd frontend && npm run dev\" \"wait-on http://localhost:5173 && electron .\"",
    "dev:frontend": "cd frontend && npm run dev",
    "dev:backend": "cd backend && python main.py",
    "build": "cd frontend && npm run build",
    "build:backend": "cd backend && pyinstaller backend.spec --clean",
    "electron:dev": "wait-on http://localhost:5173 && electron .",
    "dist": "npm run build && npm run build:backend && electron-builder",
    "dist:mac": "npm run build && npm run build:backend && electron-builder --mac",
    "dist:win": "npm run build && npm run build:backend && electron-builder --win"
  },
  "devDependencies": {
    "electron": "^28.0.0",
    "electron-builder": "^24.9.0",
    "concurrently": "^8.2.0",
    "wait-on": "^7.2.0"
  },
  "build": {
    "appId": "com.dental.recommend",
    "productName": "牙科设备推荐Agent",
    "copyright": "Copyright © 2026 Dental Recommend Team",
    "directories": {
      "output": "release"
    },
    "files": [
      "electron/**/*",
      "frontend/dist/**/*",
      "!backend/**/*.py",
      "!backend/**/*.pyc",
      "!backend/__pycache__/**",
      "!backend/data/**",
      "!backend/node_modules/**",
      "!backend/.env",
      "!frontend/node_modules/**",
      "!frontend/src/**",
      "!release/**",
      "!*.md"
    ],
    "extraResources": [
      {
        "from": "backend/dist/backend",
        "to": "backend",
        "filter": ["**/*"]
      },
      {
        "from": "backend/config.yaml.example",
        "to": "backend/config.yaml.example"
      }
    ],
    "mac": {
      "target": "dmg",
      "icon": "electron/icon.icns",
      "category": "public.app-category.business",
      "hardenedRuntime": false,
      "gatekeeperAssess": false,
      "identity": null
    },
    "dmg": {
      "contents": [
        { "x": 130, "y": 220 },
        { "x": 410, "y": 220, "type": "link", "path": "/Applications" }
      ],
      "sign": false
    },
    "win": {
      "target": "nsis",
      "icon": "electron/icon.ico"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "牙科设备推荐Agent"
    },
    "linux": {
      "target": "AppImage",
      "icon": "electron/icon.png",
      "category": "Office"
    }
  }
}
