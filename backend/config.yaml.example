# Dental Recommend Agent Configuration
# Copy this file to config.yaml and fill in your settings

llm:
  # OpenAI API base URL (supports compatible third-party services)
  base_url: "https://api.openai.com/v1"
  # API Key (required)
  api_key: "your-api-key-here"
  # Ranking model
  ranking_model: "gpt-4o"
  # Enrichment model
  enrichment_model: "gpt-4o-mini"
  # Embedding model
  embedding_model: "text-embedding-3-small"
  # Temperature
  temperature: 0.7
  # Max tokens
  max_tokens: 4096
  # Timeout (seconds)
  timeout: 30

server:
  # Server host (local only)
  host: "127.0.0.1"
  # Server port
  port: 8765

database:
  # Database path
  path: "app.db"

qdrant:
  # Qdrant storage path
  path: "qdrant"
  # Collection name
  collection: "products"
